# ============================================
# Novix Gift Bot — Конфигурация окружения
# Скопируйте этот файл в .env и заполните свои значения
# ============================================

# --- Telegram Bot ---
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-Example
BOT_USERNAME=YourBot_Username
BOT_NAME=Your Bot Name

# --- Администраторы (Telegram ID через запятую) ---
ADMIN_IDS=123456789,987654321

# --- Поддержка ---
SUPPORT_USERNAME=@YourSupport
MANAGER_USERNAME=@YourManager

# --- Безопасность ---
SECRET_KEY=your-secret-key-change-me
DJANGO_SECRET_KEY=your-django-secret-key-change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# --- Web App (Telegram Mini App / Frontend) ---
WEBAPP_URL=https://your-username.github.io/nft-bot/frontend
BACKEND_URL=https://your-backend.com
WEBAPP_ORIGIN=https://your-username.github.io

# --- TON Blockchain ---
TON_API_BASE=https://toncenter.com/api/v2
TON_API_KEY=your-ton-api-key
TON_ESCROW_ADDRESS=UQ... ваш TON-кошелёк для эскроу

# --- Реферальная система ---
REFERRAL_COMMISSION_SHARE=0.10
